# Stratify SME OS Environment Variables Example
PROJECT_NAME="SME Business Operating System"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# Database Configuration (use sqlite+aiosqlite for async local dev)
DATABASE_URL="sqlite+aiosqlite:///./sme_platform.db"

# Local Ollama AI settings
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="gemma:latest"

# File Ingestion uploads path
UPLOAD_DIR="./uploads"
